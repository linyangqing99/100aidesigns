{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build:vercel",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "(?<vercelHost>.*\\.vercel\\.app)"
        }
      ],
      "destination": "https://100ai.design/:path*",
      "statusCode": 301
    }
  ]
}
